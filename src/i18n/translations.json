        },
        {
          "question": "Who sets the discount percentage?",
          "answer": "You do. Based on our experience, we recommend the most effective percentage for your category (usually 10–30%)."
        },
        {
          "question": "How does the QR code work?",
          "answer": "The customer shows their personal QR code in the app to the cashier. The cashier scans it and applies the discount — the process takes 5 seconds."
        },
        {
          "question": "How do I track results?",
          "answer": "The Business Panel shows real-time statistics on visit count, average check, and returning customers."
        }
